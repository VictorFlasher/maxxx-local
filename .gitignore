```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled files
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Dependencies
.venv/
venv/
env/
node_modules/

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# OS generated files
.DS_Store
Thumbs.db
```