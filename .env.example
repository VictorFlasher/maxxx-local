# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_secure_password_here

# JWT настройки
SECRET_KEY=generate_a_strong_random_key_here_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis (опционально, для распределённого хранения и кэширования)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Загрузка файлов
UPLOAD_DIR=uploads
MAX_FILE_SIZE_BYTES=2097152

# Окружение (production/development)
ENVIRONMENT=development

# Уникальный ID экземпляра (для кластеризации)
INSTANCE_ID=instance-1
